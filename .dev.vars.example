# 本地开发调试变量示例
# 复制此文件为 .dev.vars，填入真实值后本地 wrangler dev 可读取
# 注意：.dev.vars 已在 .gitignore 中，切勿提交真实凭据

# 非敏感运行参数
MAIL2TG_SUMMARY_LIMIT=160
MAIL2TG_LOG_LEVEL=info

# Telegram Bot（通过 @BotFather 获取 Token；Chat ID 通过 @userinfobot 或 API 获取）
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_DEFAULT_CHAT_ID=replace-me

# Gmail（登录账号 + Google 账号后台生成的「应用专用密码」）
GMAIL_USERNAME_SECRET=yangyioryy@gmail.com
GMAIL_PASSWORD_SECRET=replace-with-app-password

# QQ 邮箱（登录账号 + QQ 邮箱设置中生成的「授权码」）
QQ_USERNAME_SECRET=yangyioryy@qq.com
QQ_PASSWORD_SECRET=replace-with-auth-code

# CSU 邮箱（登录账号 + 学校邮箱密码）
CSU_USERNAME_SECRET=8209230623@csu.edu.cn
CSU_PASSWORD_SECRET=replace-with-csu-password
